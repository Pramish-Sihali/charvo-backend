# Supavisor transaction-mode pooler URL (port 6543).
# Find at: Supabase Dashboard > Project Settings > Database > Connection string > Transaction pooler
# Replace [YOUR-PASSWORD] with your real DB password. Username MUST include the project ref.
DATABASE_URL=postgresql+psycopg://postgres.owwlbuhruomvntynvndv:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# Random hex string used to sign JWTs. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-random-hex
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Comma-separated list of allowed CORS origins. Use * for local dev.
ALLOWED_ORIGINS=*

# Port the API listens on. The ECS task definition pins containerPort 8000 in production.
PORT=8000
